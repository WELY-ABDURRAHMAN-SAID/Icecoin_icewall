package main

import (
	"fmt"
	"icecoin/network"
	"os"
)

func main() {
	if len(os.Args) < 2 {
		fmt.Println("Usage: go run main.go [port]")
		return
	}

	port := os.Args[1]
	address := ":" + port

	node := network.NewNode(address)

	fmt.Println("Ice Coin P2P Node ❄ running on", address)
	node.Start()
}